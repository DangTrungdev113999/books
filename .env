# URL của Cloudflare Worker gửi feedback lên Telegram.
# Để trống → form góp ý vẫn hiện nhưng báo "chưa cấu hình worker".
# Điền sau khi deploy worker, ví dụ: VITE_WORKER_URL=https://your-worker.workers.dev
VITE_WORKER_URL=

# ── Vbee TTS (tính năng "đọc sách") ─────────────────────────────────────────
# KEY THẬT đặt trong .env.local (đã .gitignore) — KHÔNG điền vào file này.
# Đọc bởi scripts/tts.mjs (chạy `npm run build:audio`). KHÔNG prefix VITE_.
#   VBEE_APP_ID=<app-id-uuid>
#   VBEE_TOKEN=<jwt-tu-vbee-studio>
#   VBEE_VOICE_CODE=hn_female_ngochuyen_full_24k-st   # tuỳ chọn (mặc định: Ngọc Huyền 2.0)
#
# ── Groq Whisper (căn timing karaoke read-along) ────────────────────────────
# KEY THẬT trong .env.local (đã .gitignore). Đọc bởi scripts/align.mjs (build:align).
# Free key ở console.groq.com. KHÔNG prefix VITE_.
#   GROQ_API_KEY=gsk_...
